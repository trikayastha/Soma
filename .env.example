# PostHog analytics (client-side, safe to expose the public project key)
VITE_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Email capture for /api/subscribe (server-side secret — never a VITE_ prefix)
RESEND_API_KEY=re_your_key_here
# Optional: pin a specific audience; defaults to your first Resend audience.
# RESEND_AUDIENCE_ID=
# Or, instead of Resend, forward to a webhook (Zapier / Make / Google Sheet):
# SUBSCRIBE_WEBHOOK_URL=
